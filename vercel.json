{
  "version": 2,
  "builds": [
    {
      "src": "CtrlRoom/frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "CtrlRoom/frontend/$1"
    }
  ],
  "env": {
    "NEXT_PUBLIC_BACKEND_URL": "@next_public_backend_url"
  },
  "functions": {
    "CtrlRoom/frontend/**/*.js": {
      "maxDuration": 10
    }
  }
}